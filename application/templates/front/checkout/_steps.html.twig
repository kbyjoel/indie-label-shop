{# currentStep: 'address' | 'shipment' | 'payment' #}
{% set steps = [
    {key: 'address', label: 'checkout.steps.address', route: 'front_checkout_address'},
    {key: 'shipment', label: 'checkout.steps.shipment', route: 'front_checkout_shipment'},
    {key: 'payment', label: 'checkout.steps.payment', route: 'front_checkout_payment'},
] %}
{% set stepOrder = {address: 0, shipment: 1, payment: 2} %}
{% set currentIndex = stepOrder[currentStep] %}

<nav aria-label="{{ 'checkout.steps.aria_label'|trans }}">
    <ol class="flex items-center gap-0">
        {% for i, step in steps %}
            {% set isDone = i < currentIndex %}
            {% set isCurrent = i == currentIndex %}
            <li class="flex items-center {% if not loop.last %}flex-1{% endif %}">
                <span class="flex items-center gap-2 text-sm font-medium
                    {{ isCurrent ? 'text-accent' : (isDone ? 'text-black' : 'text-muted') }}">
                    <span class="flex h-6 w-6 items-center justify-center rounded-full text-xs
                        {{ isCurrent ? 'bg-accent text-white' : (isDone ? 'bg-black text-white' : 'border border-border text-muted') }}">
                        {% if isDone %}
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                        {% else %}
                            {{ i + 1 }}
                        {% endif %}
                    </span>
                    {{ step.label|trans }}
                </span>
                {% if not loop.last %}
                    <span class="mx-3 h-px flex-1 bg-border" aria-hidden="true"></span>
                {% endif %}
            </li>
        {% endfor %}
    </ol>
</nav>
