{% extends 'front/layout.html.twig' %}

{% block page_title %}{{ album.name }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8"
     data-controller="cart"
     data-cart-add-url-value="{{ path('front_cart_add') }}">

    <div class="lg:flex lg:gap-16">

        {# Artwork #}
        <div class="mb-10 lg:mb-0 lg:w-80 lg:shrink-0">
            <img src="{{ album.artwork|aropixel_imagine_filter('album_artwork') }}"
                 alt="{{ album.artwork ? album.artwork.attrAlt : album.name }}"
                 class="w-full max-w-xs mx-auto lg:mx-0 rounded-lg shadow-md object-cover aspect-square">
        </div>

        {# Metadata, buy section & tracklist #}
        <div class="flex-1 min-w-0">

            {% if album.band %}
                <p class="text-sm text-muted mb-2">
                    <a href="{{ path('front_band_show', {slug: album.band.slug}) }}"
                       class="hover:text-accent transition-colors">{{ album.band.name }}</a>
                </p>
            {% endif %}

            <h1 class="text-3xl font-display font-bold tracking-tight sm:text-4xl">{{ album.name }}</h1>

            <dl class="mt-4 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted">
                {% if album.releaseDate %}
                    <div>
                        <dt class="inline font-medium text-inherit">{{ 'album.show.release_date'|trans }}&nbsp;</dt>
                        <dd class="inline">{{ album.releaseDate|date('d/m/Y') }}</dd>
                    </div>
                {% endif %}
                {% if album.catalogNumber %}
                    <div>
                        <dt class="inline font-medium text-inherit">{{ 'album.show.catalog_number'|trans }}&nbsp;</dt>
                        <dd class="inline">{{ album.catalogNumber }}</dd>
                    </div>
                {% endif %}
            </dl>

            {% if album.description %}
                <div class="mt-6 prose prose-sm max-w-none text-muted">
                    {{ album.description|nl2br }}
                </div>
            {% endif %}

            {# Releases (buy full album) #}
            {% if releases is not empty %}
                <section class="mt-8">
                    <h2 class="mb-3 text-base font-semibold">{{ 'album.show.buy_releases'|trans }}</h2>
                    <ul class="space-y-3">
                        {% for release in releases %}
                            <li class="flex items-center justify-between gap-4 rounded-md border border-border p-4">
                                <div>
                                    <p class="font-medium">{{ release.name }}</p>
                                    {% if release.price is not null %}
                                        <p class="text-sm text-muted mt-0.5">
                                            {{ (release.price / 100)|number_format(2, ',', '\u{202F}') }} €
                                        </p>
                                    {% endif %}
                                </div>
                                {% if release.price is not null %}
                                    <form data-action="submit->cart#add">
                                        <input type="hidden" name="variantId" value="{{ release.id }}">
                                        <input type="hidden" name="qty" value="1">
                                        <button type="submit"
                                                class="rounded-md bg-accent px-4 py-2 text-sm font-semibold text-white hover:bg-accent/90 transition-colors">
                                            {{ 'product.show.add_to_cart'|trans }}
                                        </button>
                                    </form>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                </section>
            {% endif %}

            {# Tracklist #}
            {% if album.tracklists is not empty %}
                <section class="mt-10">
                    <h2 class="mb-4 text-lg font-display font-semibold">
                        {{ 'album.show.tracklist'|trans }}
                    </h2>
                    <ol class="divide-y divide-border">
                        {% for tracklist in album.tracklists %}
                            {% set track = tracklist.track %}
                            {% if track %}
                                {{ include('front/partials/_track_row.html.twig', {
                                    trackIndex: loop.index,
                                    track: track,
                                    previewUrl: trackUrls[track.id].previewUrl ?? null,
                                    waveformUrl: trackUrls[track.id].waveformUrl ?? null,
                                    cartAddUrl: path('front_cart_add'),
                                }) }}
                            {% endif %}
                        {% endfor %}
                    </ol>
                </section>
            {% endif %}

        </div>

    </div>

</div>
{% endblock %}
