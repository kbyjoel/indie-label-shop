{% extends 'front/layout.html.twig' %}

{% block page_title %}{{ 'home.title'|trans }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">

    {# Hero #}
    <section class="mb-16 text-center">
        <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
            {{ 'home.headline'|trans }}
        </h1>
        <p class="mt-4 text-lg text-muted">
            {{ 'home.subheadline'|trans }}
        </p>
    </section>

    {# Latest releases #}
    <section class="mb-16">
        <div class="mb-6 flex items-center justify-between">
            <h2 class="text-2xl font-display font-bold tracking-tight">
                {{ 'home.latest_releases'|trans }}
            </h2>
            <a href="{{ path('front_album_index') }}"
               class="text-sm text-accent hover:text-accent-hover transition-colors">
                {{ 'home.see_all_albums'|trans }} →
            </a>
        </div>

        {% if latestAlbums is empty %}
            <p class="text-sm text-muted">{{ 'home.no_releases'|trans }}</p>
        {% else %}
            <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-6">
                {% for album in latestAlbums %}
                    {{ include('front/partials/_album_card.html.twig') }}
                {% endfor %}
            </div>
        {% endif %}
    </section>

    {# Artists #}
    <section>
        <div class="mb-6 flex items-center justify-between">
            <h2 class="text-2xl font-display font-bold tracking-tight">
                {{ 'home.artists'|trans }}
            </h2>
            <a href="{{ path('front_band_index') }}"
               class="text-sm text-accent hover:text-accent-hover transition-colors">
                {{ 'home.see_all_artists'|trans }} →
            </a>
        </div>

        {% if bands is empty %}
            <p class="text-sm text-muted">{{ 'home.no_artists'|trans }}</p>
        {% else %}
            <div class="grid grid-cols-3 gap-6 sm:grid-cols-4 lg:grid-cols-8">
                {% for band in bands %}
                    {{ include('front/partials/_band_card.html.twig') }}
                {% endfor %}
            </div>
        {% endif %}
    </section>

</div>
{% endblock %}
