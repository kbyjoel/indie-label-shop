{% extends 'front/layout.html.twig' %}

{% block page_title %}{{ product.name }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <div class="lg:flex lg:gap-16">

        {# Product image #}
        <div class="mb-10 lg:mb-0 lg:w-80 lg:shrink-0">
            {% if product.image %}
                <img src="{{ product.image|aropixel_imagine_filter('product_image') }}"
                     alt="{{ product.image.attrAlt ?? product.name }}"
                     class="w-full max-w-xs mx-auto lg:mx-0 rounded-lg shadow-md object-cover aspect-square">
            {% else %}
                <div class="w-full max-w-xs mx-auto lg:mx-0 rounded-lg bg-border aspect-square flex items-center justify-center text-muted text-sm">
                    {{ 'product.card.no_image'|trans }}
                </div>
            {% endif %}
        </div>

        {# Product details #}
        <div class="flex-1 min-w-0">
            <h1 class="text-3xl font-display font-bold tracking-tight sm:text-4xl">{{ product.name }}</h1>

            {% if product.description %}
                <div class="mt-6 prose prose-sm max-w-none text-muted">
                    {{ product.description|nl2br }}
                </div>
            {% endif %}

            {# Variant selector + add to cart #}
            {% set hasVariants = product.variants|length > 0 %}
            {% if hasVariants %}
                <div class="mt-8"
                     data-controller="product-variant cart"
                     data-product-variant-variants-value="{{ variantsJson|e('html_attr') }}"
                     data-cart-add-url-value="{{ path('front_cart_add') }}">

                    {# Option selects #}
                    {% if product.options|length > 0 %}
                        <div class="space-y-4 mb-6">
                            {% for option in product.options %}
                                <div>
                                    <label class="block text-sm font-medium mb-1">{{ option.name }}</label>
                                    <select data-product-variant-target="optionSelect"
                                            class="rounded-md border border-border bg-surface px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent w-full max-w-xs">
                                        {% for value in option.values %}
                                            <option value="{{ value.id }}">{{ value.value }}</option>
                                        {% endfor %}
                                    </select>
                                </div>
                            {% endfor %}
                        </div>
                    {% endif %}

                    {# Price display #}
                    <p class="mb-4 text-2xl font-bold">
                        <span data-product-variant-target="priceDisplay">
                            {% if product.variants|first.price is not null %}
                                {{ (product.variants|first.price / 100)|number_format(2, ',', '\u{202F}') }} €
                            {% endif %}
                        </span>
                    </p>

                    {# Add to cart form #}
                    <form data-action="submit->cart#add"
                          data-cart-target="form">
                        <input type="hidden" name="variantId"
                               data-product-variant-target="variantIdInput"
                               value="{{ product.variants|first.id ?? '' }}">
                        <input type="hidden" name="qty" value="1">
                        <button type="submit"
                                data-product-variant-target="addButton"
                                data-cart-target="submitButton"
                                class="rounded-md bg-accent px-6 py-3 text-sm font-semibold text-white hover:bg-accent/90 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                            {{ 'product.show.add_to_cart'|trans }}
                        </button>
                    </form>

                    {# Success / error feedback #}
                    <p data-cart-target="feedback" class="mt-3 text-sm hidden"></p>
                </div>
            {% endif %}
        </div>

    </div>
</div>
{% endblock %}
