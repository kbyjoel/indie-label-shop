{% extends 'front/layout.html.twig' %}

{% block page_title %}{{ 'product.index.title'|trans }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">

    <h1 class="mb-8 text-3xl font-display font-bold tracking-tight sm:text-4xl">
        {{ 'product.index.title'|trans }}
    </h1>

    {% if products.currentPageResults|length == 0 %}
        <p class="text-muted">{{ 'product.index.empty'|trans }}</p>
    {% else %}
        <div class="grid grid-cols-2 gap-6 sm:grid-cols-3 lg:grid-cols-4">
            {% for product in products.currentPageResults %}
                {{ include('front/partials/_product_card.html.twig') }}
            {% endfor %}
        </div>

        {% if products.haveToPaginate %}
            <nav class="mt-12 flex items-center justify-center gap-2" aria-label="{{ 'pagination.label'|trans }}">
                {% if products.hasPreviousPage %}
                    <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({page: products.previousPage})) }}"
                       class="rounded-md border border-border px-4 py-2 text-sm hover:bg-surface transition-colors">
                        {{ 'pagination.previous'|trans }}
                    </a>
                {% endif %}
                <span class="text-sm text-muted">
                    {{ 'pagination.page_x_of_y'|trans({page: products.currentPage, total: products.nbPages}) }}
                </span>
                {% if products.hasNextPage %}
                    <a href="{{ path(app.request.attributes.get('_route'), app.request.attributes.get('_route_params')|merge({page: products.nextPage})) }}"
                       class="rounded-md border border-border px-4 py-2 text-sm hover:bg-surface transition-colors">
                        {{ 'pagination.next'|trans }}
                    </a>
                {% endif %}
            </nav>
        {% endif %}
    {% endif %}

</div>
{% endblock %}
