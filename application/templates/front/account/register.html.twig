{% extends 'front/layout.html.twig' %}

{% block page_title %}{{ 'account.register.title'|trans }}{% endblock %}

{% block content %}
<div class="mx-auto max-w-md px-4 py-16 sm:px-6">

    <div class="rounded-xl border border-border bg-white p-8 shadow-sm">
        <h1 class="mb-6 text-2xl font-display font-bold tracking-tight">{{ 'account.register.title'|trans }}</h1>

        {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            {% if form.vars.errors|length > 0 %}
                <div class="mb-4 rounded-md bg-red-50 px-4 py-3 text-sm text-red-700 border border-red-200">
                    {{ form_errors(form) }}
                </div>
            {% endif %}

            <div class="mb-4 grid grid-cols-2 gap-4">
                <div>
                    {{ form_label(form.firstName, null, {label_attr: {class: 'mb-1 block text-sm font-medium'}}) }}
                    {{ form_widget(form.firstName, {attr: {class: 'w-full rounded-md border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent'}}) }}
                    {{ form_errors(form.firstName) }}
                </div>
                <div>
                    {{ form_label(form.lastName, null, {label_attr: {class: 'mb-1 block text-sm font-medium'}}) }}
                    {{ form_widget(form.lastName, {attr: {class: 'w-full rounded-md border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent'}}) }}
                    {{ form_errors(form.lastName) }}
                </div>
            </div>

            <div class="mb-4">
                {{ form_label(form.email, null, {label_attr: {class: 'mb-1 block text-sm font-medium'}}) }}
                {{ form_widget(form.email, {attr: {class: 'w-full rounded-md border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent', autocomplete: 'email'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="mb-4">
                {{ form_label(form.plainPassword.first, null, {label_attr: {class: 'mb-1 block text-sm font-medium'}}) }}
                {{ form_widget(form.plainPassword.first, {attr: {class: 'w-full rounded-md border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent', autocomplete: 'new-password'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>

            <div class="mb-6">
                {{ form_label(form.plainPassword.second, null, {label_attr: {class: 'mb-1 block text-sm font-medium'}}) }}
                {{ form_widget(form.plainPassword.second, {attr: {class: 'w-full rounded-md border border-border px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-accent', autocomplete: 'new-password'}}) }}
                {{ form_errors(form.plainPassword) }}
            </div>

            <div class="mb-6 flex items-start gap-2">
                {{ form_widget(form.agreeTerms, {attr: {class: 'mt-0.5 h-4 w-4 rounded border-border text-accent'}}) }}
                {{ form_label(form.agreeTerms, null, {label_attr: {class: 'text-sm text-muted'}}) }}
                {{ form_errors(form.agreeTerms) }}
            </div>

            <button type="submit"
                    class="w-full rounded-md bg-accent px-4 py-2.5 text-sm font-semibold text-white hover:bg-accent/90 transition-colors">
                {{ 'account.register.submit'|trans }}
            </button>

        {{ form_end(form) }}

        <p class="mt-6 text-center text-sm text-muted">
            {{ 'account.register.already_account'|trans }}
            <a href="{{ path('front_account_login', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
               class="text-accent hover:underline">{{ 'account.register.login_link'|trans }}</a>
        </p>
    </div>

</div>
{% endblock %}
