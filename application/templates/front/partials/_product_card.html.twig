{% set productSlug = product.slug %}
{% set href = productSlug ? path('front_product_show', {slug: productSlug}) : '#' %}
{% set minPrice = null %}
{% for variant in product.variants %}
    {% if variant.price is not null and (minPrice is null or variant.price < minPrice) %}
        {% set minPrice = variant.price %}
    {% endif %}
{% endfor %}
<article class="group">
    <a href="{{ href }}" class="block overflow-hidden rounded-lg bg-surface">
        {% if product.image %}
            <img src="{{ product.image|aropixel_imagine_filter('product_card') }}"
                 alt="{{ product.image.attrAlt ?? product.name }}"
                 class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105"
                 loading="lazy">
        {% else %}
            <div class="w-full aspect-square bg-border flex items-center justify-center text-muted text-xs">
                {{ 'product.card.no_image'|trans }}
            </div>
        {% endif %}
    </a>
    <div class="mt-3">
        <h3 class="font-semibold leading-tight truncate">
            <a href="{{ href }}" class="hover:text-accent transition-colors">{{ product.name }}</a>
        </h3>
        {% if minPrice is not null %}
            <p class="mt-1 text-sm font-medium">
                {{ 'product.card.from_price'|trans }} {{ (minPrice / 100)|number_format(2, ',', '\u{202F}') }} €
            </p>
        {% endif %}
    </div>
</article>
