<header class="border-b border-border bg-white" data-turbo-permanent id="site-header">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between gap-6">

            {# Logo / site name #}
            <a href="{{ path('front_home_index', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
               class="shrink-0 text-lg font-semibold tracking-tight">
                {{ 'site.name'|trans }}
            </a>

            {# Primary navigation #}
            <nav class="hidden items-center gap-6 text-sm font-medium md:flex" aria-label="{{ 'nav.aria_label'|trans }}">
                <a href="{{ path('front_album_index', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
                   class="text-muted transition-colors hover:text-black">{{ 'nav.albums'|trans }}</a>
                <a href="{{ path('front_band_index', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
                   class="text-muted transition-colors hover:text-black">{{ 'nav.artists'|trans }}</a>
                <a href="{{ path('front_product_index', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
                   class="text-muted transition-colors hover:text-black">{{ 'nav.shop'|trans }}</a>
            </nav>

            {# Right-side actions #}
            <div class="flex items-center gap-4">

                {# Language switcher — visible only in multi-locale mode #}
                {% if app_locales|length > 1 %}
                    <div class="flex items-center gap-2 text-xs font-medium" aria-label="{{ 'nav.language_switcher'|trans }}">
                        {% set route = app.request.attributes.get('_route') %}
                        {% set params = app.request.attributes.get('_route_params') ?? {} %}
                        {% for locale in app_locales %}
                            <a href="{{ path(route, params|merge({_locale: locale})) }}"
                               class="{{ app.request.locale == locale ? 'font-bold text-black' : 'text-muted hover:text-black' }} uppercase transition-colors"
                               {% if app.request.locale == locale %}aria-current="true"{% endif %}>
                                {{ locale }}
                            </a>
                        {% endfor %}
                    </div>
                {% endif %}

                {# Cart icon #}
                <a href="{{ path('front_cart_index', app_locales|length > 1 ? {_locale: app.request.locale} : {}) }}"
                   class="relative flex items-center gap-1.5 text-sm text-muted hover:text-black transition-colors"
                   aria-label="{{ 'nav.cart'|trans }}"
                   data-controller="cart"
                   data-cart-count-value="{{ cart_item_count() }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                    </svg>
                    <span id="cart-count" data-cart-target="countBadge" class="text-xs">{{ cart_item_count() }}</span>
                </a>

                {# Mobile menu toggle — behaviour wired via Stimulus in a later step #}
                <button type="button"
                        class="inline-flex items-center justify-center p-2 text-muted hover:text-black md:hidden"
                        aria-label="{{ 'nav.menu_toggle'|trans }}">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                    </svg>
                </button>

            </div>
        </div>
    </div>
</header>
