{% set href = path('front_album_show', {slug: album.slug}) %}
<article class="group">
    <a href="{{ href }}" class="block overflow-hidden rounded-lg">
        <img src="{{ album.artwork|aropixel_imagine_filter('album_card') }}"
             alt="{{ album.artwork ? album.artwork.attrAlt : album.name }}"
             class="w-full aspect-square object-cover transition-transform duration-300 group-hover:scale-105"
             loading="lazy">
    </a>
    <div class="mt-3">
        <h3 class="font-display font-semibold leading-tight">
            <a href="{{ href }}" class="hover:text-accent transition-colors">{{ album.name }}</a>
        </h3>
        {% if album.band %}
            <p class="mt-1 text-sm text-muted">
                <a href="{{ path('front_band_show', {slug: album.band.slug}) }}"
                   class="hover:text-accent transition-colors">{{ album.band.name }}</a>
            </p>
        {% endif %}
        {% if album.releaseDate %}
            <p class="mt-1 text-xs text-muted">{{ album.releaseDate|date('Y') }}</p>
        {% endif %}
    </div>
</article>
