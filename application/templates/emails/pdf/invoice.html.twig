<!DOCTYPE html>
<html lang="{{ locale|replace({'_': '-'}) }}">
<head>
<meta charset="UTF-8">
<title>{{ 'email.invoice.title'|trans({}, 'messages', locale) }} {{ order.number }}</title>
<style>
  body { margin: 0; padding: 40px; font-family: DejaVu Sans, sans-serif; font-size: 13px; color: #1a1a1a; }
  h1 { font-size: 22px; font-weight: 700; margin: 0 0 4px; }
  .label { font-size: 11px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; }
  .section { margin-bottom: 28px; }
  hr { border: none; border-top: 1px solid #e5e7eb; margin: 24px 0; }
  table { width: 100%; border-collapse: collapse; }
  th { text-align: left; font-size: 11px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; padding: 6px 0; border-bottom: 1px solid #e5e7eb; }
  td { padding: 10px 0; font-size: 13px; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
  td.right { text-align: right; }
  .total-row td { font-weight: 700; border-bottom: none; padding-top: 14px; }
  address { font-style: normal; line-height: 1.7; }
</style>
</head>
<body>

<div class="section" style="display:flex;justify-content:space-between;">
  <div>
    <h1>{{ 'email.invoice.title'|trans({}, 'messages', locale) }}</h1>
    <p class="label" style="margin:4px 0 0;">N° {{ order.number }}</p>
  </div>
  <div style="text-align:right;">
    <p style="margin:0;font-weight:600;">Indie Label</p>
    <p style="margin:4px 0 0;color:#6b7280;font-size:12px;">{{ 'email.invoice.date_label'|trans({'date': "now"|date('email.invoice.date_format'|trans({}, 'messages', locale))}, 'messages', locale) }}</p>
  </div>
</div>

<hr>

{% if order.shippingAddress %}
<div class="section">
  <p class="label" style="margin:0 0 8px;">{{ 'email.invoice.bill_to'|trans({}, 'messages', locale) }}</p>
  <address>
    {{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}<br>
    {% if order.shippingAddress.company %}{{ order.shippingAddress.company }}<br>{% endif %}
    {{ order.shippingAddress.street }}<br>
    {{ order.shippingAddress.postcode }} {{ order.shippingAddress.city }}<br>
    {{ order.shippingAddress.countryCode }}
  </address>
</div>
<hr>
{% endif %}

<div class="section">
  <table>
    <thead>
      <tr>
        <th>{{ 'email.invoice.col_item'|trans({}, 'messages', locale) }}</th>
        <th>{{ 'email.invoice.col_qty'|trans({}, 'messages', locale) }}</th>
        <th>{{ 'email.invoice.col_unit_price'|trans({}, 'messages', locale) }}</th>
        <th class="right">{{ 'email.invoice.col_total'|trans({}, 'messages', locale) }}</th>
      </tr>
    </thead>
    <tbody>
      {% for item in order.items %}
        {% set product = item.variant ? item.variant.product : null %}
        <tr>
          <td>{{ product ? product.name : '—' }}</td>
          <td>{{ item.quantity }}</td>
          <td>{{ (item.unitPrice / 100)|number_format(2, ',', ' ') }} €</td>
          <td class="right">{{ (item.total / 100)|number_format(2, ',', ' ') }} €</td>
        </tr>
      {% endfor %}
    </tbody>
    <tfoot>
      <tr class="total-row">
        <td colspan="3">{{ 'email.invoice.total_row'|trans({}, 'messages', locale) }}</td>
        <td class="right">{{ (order.total / 100)|number_format(2, ',', ' ') }} €</td>
      </tr>
    </tfoot>
  </table>
</div>

</body>
</html>
