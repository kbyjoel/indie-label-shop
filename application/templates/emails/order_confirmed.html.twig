<!DOCTYPE html>
<html lang="{{ locale|replace({'_': '-'}) }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ 'email.order_confirmed.html_title'|trans({'number': order.number}, 'messages', locale) }}</title>
<style>
  body { margin: 0; padding: 0; background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1a1a1a; }
  .wrapper { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
  .header { background: #1a1a1a; padding: 32px 40px; }
  .header h1 { margin: 0; color: #ffffff; font-size: 20px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }
  .body { padding: 40px; }
  h2 { font-size: 16px; font-weight: 600; margin: 0 0 16px; color: #1a1a1a; }
  table { width: 100%; border-collapse: collapse; margin-bottom: 24px; }
  th { text-align: left; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; padding: 8px 0; border-bottom: 1px solid #e5e7eb; }
  td { padding: 12px 0; font-size: 14px; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
  td.right { text-align: right; }
  .total-row td { font-weight: 700; font-size: 15px; border-bottom: none; padding-top: 16px; }
  .address-block { background: #f9fafb; border-radius: 6px; padding: 16px 20px; margin-bottom: 24px; font-size: 14px; line-height: 1.6; }
  .digital-notice { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 14px 18px; margin-bottom: 24px; font-size: 14px; color: #1d4ed8; }
  .cta { display: inline-block; background: #1a1a1a; color: #ffffff; text-decoration: none; padding: 12px 24px; border-radius: 6px; font-size: 14px; font-weight: 600; margin-top: 8px; }
  .footer { padding: 24px 40px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; text-align: center; }
</style>
</head>
<body>
<div class="wrapper">
  <div class="header">
    <h1>{{ 'email.order_confirmed.header'|trans({}, 'messages', locale) }}</h1>
  </div>
  <div class="body">
    <p style="font-size:15px;margin:0 0 24px;">{{ 'email.order_confirmed.intro'|trans({'number': order.number}, 'messages', locale) }}</p>

    <h2>{{ 'email.order_confirmed.items_heading'|trans({}, 'messages', locale) }}</h2>
    <table>
      <thead>
        <tr>
          <th>{{ 'email.order_confirmed.col_item'|trans({}, 'messages', locale) }}</th>
          <th>{{ 'email.order_confirmed.col_qty'|trans({}, 'messages', locale) }}</th>
          <th class="right">{{ 'email.order_confirmed.col_price'|trans({}, 'messages', locale) }}</th>
        </tr>
      </thead>
      <tbody>
        {% for item in order.items %}
          {% set product = item.variant ? item.variant.product : null %}
          <tr>
            <td>{{ product ? product.name : '—' }}</td>
            <td>{{ item.quantity }}</td>
            <td class="right">{{ (item.total / 100)|number_format(2, ',', '\u{202F}') }}&nbsp;€</td>
          </tr>
        {% endfor %}
      </tbody>
      <tfoot>
        <tr class="total-row">
          <td colspan="2">{{ 'email.order_confirmed.total'|trans({}, 'messages', locale) }}</td>
          <td class="right">{{ (order.total / 100)|number_format(2, ',', '\u{202F}') }}&nbsp;€</td>
        </tr>
      </tfoot>
    </table>

    {% if order.shippingAddress %}
      <h2>{{ 'email.order_confirmed.shipping_heading'|trans({}, 'messages', locale) }}</h2>
      <div class="address-block">
        {{ order.shippingAddress.firstName }} {{ order.shippingAddress.lastName }}<br>
        {% if order.shippingAddress.company %}{{ order.shippingAddress.company }}<br>{% endif %}
        {{ order.shippingAddress.street }}<br>
        {{ order.shippingAddress.postcode }} {{ order.shippingAddress.city }}<br>
        {{ order.shippingAddress.countryCode }}
      </div>
    {% endif %}

    {% set hasDigital = false %}
    {% for item in order.items %}
      {% if item.variant is instanceof('App\\Entity\\Release') and item.variant.media is not null and item.variant.media.isDigital %}
        {% set hasDigital = true %}
      {% endif %}
    {% endfor %}
    {% if hasDigital %}
      <div class="digital-notice">
        {{ 'email.order_confirmed.digital_notice'|trans({}, 'messages', locale) }}
      </div>
    {% endif %}

    <a href="{{ url('front_account_dashboard', app_locales|length > 1 ? {_locale: locale} : {}) }}" class="cta">{{ 'email.order_confirmed.cta'|trans({}, 'messages', locale) }}</a>
  </div>
  <div class="footer">
    {{ 'email.order_confirmed.footer'|trans({}, 'messages', locale) }}
  </div>
</div>
</body>
</html>
