<!DOCTYPE html>
<html lang="{{ locale|replace({'_': '-'}) }}">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ 'email.download_ready.html_title'|trans({'number': orderNumber}, 'messages', locale) }}</title>
<style>
  body { margin: 0; padding: 0; background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1a1a1a; }
  .wrapper { max-width: 600px; margin: 32px auto; background: #ffffff; border-radius: 8px; overflow: hidden; }
  .header { background: #1a1a1a; padding: 32px 40px; }
  .header h1 { margin: 0; color: #ffffff; font-size: 20px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; }
  .body { padding: 40px; }
  .cta { display: inline-block; background: #1a1a1a; color: #ffffff; text-decoration: none; padding: 14px 28px; border-radius: 6px; font-size: 15px; font-weight: 600; margin: 24px 0; }
  .meta { font-size: 13px; color: #6b7280; margin-top: 8px; }
  .footer { padding: 24px 40px; background: #f9fafb; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; text-align: center; }
</style>
</head>
<body>
<div class="wrapper">
  <div class="header">
    <h1>{{ 'email.download_ready.header'|trans({}, 'messages', locale) }}</h1>
  </div>
  <div class="body">
    <p style="font-size:15px;margin:0 0 8px;">{{ 'email.download_ready.intro'|trans({'number': orderNumber, 'format': format|upper}, 'messages', locale) }}</p>
    <p style="font-size:14px;color:#6b7280;margin:0 0 24px;">
      {% if expiresAt %}
        {{ 'email.download_ready.expires_until'|trans({'date': expiresAt|date('email.download_ready.date_format'|trans({}, 'messages', locale))}, 'messages', locale) }}
      {% else %}
        {{ 'email.download_ready.expires'|trans({}, 'messages', locale) }}
      {% endif %}
    </p>

    <a href="{{ signedUrl }}" class="cta">{{ 'email.download_ready.cta'|trans({}, 'messages', locale) }}</a>

    <p class="meta">{{ 'email.download_ready.fallback_label'|trans({}, 'messages', locale) }}<br>
    <span style="word-break:break-all;color:#1d4ed8;">{{ signedUrl }}</span></p>

    <p style="font-size:13px;color:#6b7280;margin-top:32px;">{{ 'email.download_ready.account_notice'|trans({}, 'messages', locale) }}</p>
    <a href="{{ url('front_account_dashboard', app_locales|length > 1 ? {_locale: locale} : {}) }}" style="font-size:13px;color:#1a1a1a;">{{ 'email.download_ready.account_cta'|trans({}, 'messages', locale) }}</a>
  </div>
  <div class="footer">
    {{ 'email.download_ready.footer'|trans({}, 'messages', locale) }}
  </div>
</div>
</body>
</html>
