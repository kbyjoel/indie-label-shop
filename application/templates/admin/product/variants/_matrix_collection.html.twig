{% set product = form.parent.vars.data %}
{% set option1 = product.options|first %}
{% set option2 = product.options|last %}
{% set option2_values = [] %}

{# Collecter les valeurs de l'option 2 présentes dans les variantes (FormView) #}
{% for variant_form in form %}
    {% set variant = variant_form.vars.data %}
    {% for ov in variant.optionValues %}
        {% if ov.option.id == option2.id and ov.id not in option2_values|map(v => v.id) %}
            {% set option2_values = option2_values|merge([ov]) %}
        {% endif %}
    {% endfor %}
{% endfor %}

{% if option2_values|length == 0 %}
    {% for ov in option2.values %}
        {% set option2_values = option2_values|merge([ov]) %}
    {% endfor %}
{% endif %}

<table class="table table-bordered table-striped text-center" data-form-collection="list">
    <thead>
    <tr>
        <th>{{ option1.name }} \ {{ option2.name }}</th>
        {% for ov2 in option2_values %}
            <th>{{ ov2.name }}</th>
        {% endfor %}
    </tr>
    </thead>
    <tbody>
    {% set rows = {} %}
    {% for variant_form in form %}
        {% set variant = variant_form.vars.data %}
        {% set v_opt1 = null %}
        {% set v_opt2 = null %}
        {% for ov in variant.optionValues %}
            {% if ov.option.id == option1.id %}{% set v_opt1 = ov %}{% endif %}
            {% if ov.option.id == option2.id %}{% set v_opt2 = ov %}{% endif %}
        {% endfor %}

        {% if v_opt1 and v_opt2 %}
            {% set row_key = 'r' ~ v_opt1.id %}
            {% if rows[row_key] is not defined %}
                {% set rows = rows|merge({(row_key): {name: v_opt1.name, cols: {}}}) %}
            {% endif %}
            {% set row_data = rows[row_key] %}
            {% set col_key = 'c' ~ v_opt2.id %}
            {% set row_cols = row_data.cols|merge({(col_key): variant_form}) %}
            {% set rows = rows|merge({(row_key): row_data|merge({cols: row_cols})}) %}
        {% endif %}
    {% endfor %}

    {% if rows|length > 0 %}
        {% for row_id, row in rows %}
            <tr>
                <th class="text-left">{{ row.name }}</th>
                {% for ov2 in option2_values %}
                    {% set col_key = 'c' ~ ov2.id %}
                    {% if row.cols[col_key] is defined %}
                        {% set variant_form = row.cols[col_key] %}
                        {% set variant = variant_form.vars.data %}
                        <td class="variant-cell collection-item clickable"
                            data-form-collection="item"
                            data-form-collection-index="{{ variant_form.vars.name }}"
                            data-form-collection-edit
                            style="cursor: pointer;">
                            <div class="small">
                                <strong class="modal-collection-display-label" data-display-field-name="{{ variant_form.onHand.vars.full_name }}">{{ variant.onHand }}</strong>
                                <br>
                                <span class="text-muted"><span class="modal-collection-display-label" data-display-field-name="{{ variant_form.price.vars.full_name }}">{{ (variant.price / 100)|number_format(2) }}</span>€</span>
                            </div>
                            <div class="collection-form-container d-none">
                                <div class="collection-form-content">
                                    {{ form_widget(variant_form) }}
                                </div>
                                <div class="collection-form-actions mt-4 pt-3 border-top d-flex justify-content-between">
                                    <a class="btn btn-danger text-white delete" href="#" data-form-collection="delete">
                                        <i class="fas fa-trash me-2"></i> {{ 'text.delete'|trans }}
                                    </a>
                                    <button type="button" class="btn btn-primary" data-bs-dismiss="offcanvas">
                                        {{ 'text.close'|trans }}
                                    </button>
                                </div>
                            </div>
                        </td>
                    {% else %}
                        <td>-</td>
                    {% endif %}
                {% endfor %}
            </tr>
        {% endfor %}
    {% else %}
        <tr>
            <td colspan="{{ option2_values|length + 1 }}" class="text-center text-muted">
                Aucune variante ne correspond aux deux options sélectionnées.
            </td>
        </tr>
    {% endif %}
    </tbody>
</table>
