{% set product = form.parent.vars.data %}
<table class="table table-striped" data-form-collection="list">
    <thead>
    <tr>
        {% for option in product.options %}
            <th>{{ option.name }}</th>
        {% endfor %}
        <th>Prix</th>
        <th>Stock</th>
    </tr>
    </thead>
    <tbody>
    {% set last_group_values = {} %}
    {% for variant_form in form %}
        {% set variant = variant_form.vars.data %}
        {# Détecter si un groupe change (pour les n-1 premières options) #}
        {% set group_changed = false %}
        {% set current_group_values = [] %}
        {% for i in 0..(product.options|length - 2) %}
            {% set opt = product.options[i] %}
            {% set opt_val = null %}
            {% for ov in variant.optionValues %}
                {% if ov.option.id == opt.id %}{% set opt_val = ov.name %}{% endif %}
            {% endfor %}
            {% set current_group_values = current_group_values|merge([opt_val]) %}
            {% if last_group_values[i] is not defined or last_group_values[i] != opt_val %}
                {% set group_changed = true %}
            {% endif %}
        {% endfor %}

        {% if group_changed %}
            <tr class="table-secondary">
                <td colspan="{{ product.options|length + 2 }}">
                    {% for i in 0..(product.options|length - 2) %}
                        <strong>{{ product.options[i].name }}:</strong> {{ current_group_values[i] }}{% if not loop.last %} | {% endif %}
                    {% endfor %}
                </td>
            </tr>
            {% set last_group_values = current_group_values %}
        {% endif %}

        <tr class="variant-row collection-item clickable"
            data-form-collection="item"
            data-form-collection-index="{{ variant_form.vars.name }}"
            data-form-collection-edit
            style="cursor: pointer;">
            {% for option in product.options %}
                <td>
                    {% set value = null %}
                    {% for optionValue in variant.optionValues %}
                        {% if optionValue.option.id == option.id %}
                            {% set value = optionValue.name %}
                        {% endif %}
                    {% endfor %}
                    {{ value }}
                </td>
            {% endfor %}
            <td><span class="modal-collection-display-label" data-display-field-name="{{ variant_form.price.vars.full_name }}">{{ (variant.price / 100)|number_format(2) }}</span>€</td>
            <td><span class="modal-collection-display-label" data-display-field-name="{{ variant_form.onHand.vars.full_name }}">{{ variant.onHand }}</span></td>
            <td class="d-none">
                <div class="collection-form-container">
                    <div class="collection-form-content">
                        {{ form_widget(variant_form) }}
                    </div>
                    <div class="collection-form-actions mt-4 pt-3 border-top d-flex justify-content-between">
                        <a class="btn btn-danger text-white delete" href="#" data-form-collection="delete">
                            <i class="fas fa-trash me-2"></i> {{ 'text.delete'|trans }}
                        </a>
                        <button type="button" class="btn btn-primary" data-bs-dismiss="offcanvas">
                            {{ 'text.close'|trans }}
                        </button>
                    </div>
                </div>
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>
