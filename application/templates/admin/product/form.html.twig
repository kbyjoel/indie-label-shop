{% extends '@AropixelAdmin/Form/base.html.twig' %}
{% import '@AropixelAdmin/Macro/breadcrumb.html.twig' as nav %}
{% import '@AropixelAdmin/Macro/forms.html.twig' as forms %}

{% set is_edit = product.id is not null %}
{% set title = is_edit ? 'Modifier le produit : ' ~ product.name : 'Ajouter un produit' %}

{% block meta_title %}{{ title }}{% endblock %}
{% block header_title %}{{ title }}{% endblock %}

{% block header_breadcrumb %}
    {{ nav.breadcrumbs([
        { label: 'text.home'|trans, url: url('_admin') },
        { label: 'Product'|trans, url: path('admin_product_index') },
        { label: (product.id ? 'text.edit'|trans : 'text.add'|trans) }
    ]) }}
{% endblock %}

{% block tabbable %}
    {{ forms.tabs([
        { id: 'panel-tab-general', label: 'Général' },
        { id: 'panel-tab-variants', label: 'Déclinaisons' },
    ]) }}
{% endblock %}

{% block mainPanel %}
    {# Tab 1: General Info #}
    <div class="tab-pane active" id="panel-tab-general">
        <div class="card card-centered card-centered-large">
            <div class="card-body">
                {{ form_row(form.name) }}
                {{ form_row(form.code) }}
                {{ form_row(form.band) }}
                {{ form_row(form.description) }}
            </div>
        </div>
    </div>

    {# Tab 2: Values #}
    <div class="tab-pane" id="panel-tab-variants">
        <div class="card card-centered card-centered-large">
            <div class="card-body">
                {{ form_row(form.options) }}
                <hr />
                {% if product.options|length == 2 %}
                    {% include 'admin/product/variants/_matrix.html.twig' %}
                {% elseif product.options|length > 2 %}
                    {% include 'admin/product/variants/_grouped.html.twig' %}
                {% else %}
                    {% include 'admin/product/variants/_simple.html.twig' %}
                {% endif %}
            </div>
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasVariant" aria-labelledby="offcanvasVariantLabel" style="width: 500px;">
        <div id="offcanvas-content">
            <div class="offcanvas-header">
                <h5 class="offcanvas-title" id="offcanvasVariantLabel">Chargement...</h5>
                <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
            </div>
            <div class="offcanvas-body">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const offcanvasElement = document.getElementById('offcanvasVariant');
            const offcanvasContent = document.getElementById('offcanvas-content');

            if (!offcanvasElement) {
                console.error('Offcanvas element not found');
                return;
            }

            const bsOffcanvas = new bootstrap.Offcanvas(offcanvasElement);

            document.addEventListener('click', function(e) {
                const clickable = e.target.closest('.clickable');
                console.log(clickable);
                if (clickable) {
                    const target = clickable.hasAttribute('data-url') ? clickable : clickable.closest('[data-url]');
                    if (target) {
                        e.preventDefault();
                        e.stopPropagation();
                        const url = target.getAttribute('data-url');
                        showOffcanvas(url);
                        return false;
                    }
                }
            });

            function showOffcanvas(url) {
                // Reset content with spinner
                offcanvasContent.innerHTML = `
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title">Chargement...</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body">
                        <div class="text-center">
                            <div class="spinner-border" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                        </div>
                    </div>
                `;

                bsOffcanvas.show();

                fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    offcanvasContent.innerHTML = html;
                    initPlugins(offcanvasContent);
                    bindAjaxForm(offcanvasContent);
                });
            }

            function initPlugins(container) {
                const $container = $(container);

                // Initialize standard Select2
                $container.find(".select2").not('.select2-container').each(function() {
                    const _select = $(this);
                    let params = {};
                    let width = _select.prop('style')['width'];
                    if (width && width.length) {
                        params.width = width;
                    }
                    if (_select[0].hasAttribute("data-placeholder")) {
                        params.allowClear = true;
                    }
                    _select.select2(params);
                });

                // Initialize Ajax Select2
                $container.find(".select2-ajax").not('.select2-container').each(function() {
                    const _select = $(this);
                    let _url = _select.attr('data-url');
                    let _placeholder = _select.attr('data-placeholder');
                    let _multiple = _select.attr('data-multiple') ? true : false;

                    let params = {
                        multiple: _multiple,
                        ajax: {
                            url: _url,
                            dataType: 'json',
                            delay: 250,
                            data: function (params) {
                                return {
                                    q: params.term,
                                    page: params.page
                                };
                            },
                            processResults: function (data, params) {
                                params.page = params.page || 1;
                                return {
                                    results: data.results,
                                    pagination: {
                                        more: data.pagination.more
                                    }
                                };
                            },
                            cache: true
                        },
                        escapeMarkup: function (markup) { return markup; },
                        templateResult: function (repo) {
                            if (repo.loading) return repo.text;
                            return repo.full_name || repo.text;
                        },
                        templateSelection: function (repo) {
                            return repo.full_name || repo.text;
                        }
                    };

                    if (_select[0].hasAttribute("data-placeholder")) {
                        params.placeholder = _placeholder;
                        params.allowClear = true;
                    } else {
                        params.placeholder = "";
                    }

                    _select.select2(params);
                });
            }

            function bindAjaxForm(container) {
                const form = container.querySelector('form.ajax-form');
                if (!form) return;

                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    const formData = new FormData(form);
                    const url = form.getAttribute('action');

                    fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => {
                        if (response.status === 204) {
                            // Success, reload page or update UI
                            window.location.reload();
                        } else {
                            return response.text();
                        }
                    })
                    .then(html => {
                        if (html) {
                            offcanvasContent.innerHTML = html;
                            initPlugins(offcanvasContent);
                            bindAjaxForm(offcanvasContent);
                        }
                    });
                });
            }
        });
    </script>
{% endblock %}
