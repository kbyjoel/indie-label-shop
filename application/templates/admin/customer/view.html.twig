{% extends '@AropixelAdmin/base.html.twig' %}
{% import '@AropixelAdmin/Macro/breadcrumb.html.twig' as nav %}

{% block meta_title %}Fiche client : {{ customer.fullName }}{% endblock %}

{% block header_title %}Fiche client : {{ customer.fullName }}{% endblock %}

{% block header_breadcrumb %}
    {{ nav.breadcrumbs([
        { label: 'text.home', url: url('_admin') },
        { label: 'Clients', url: url('admin_customer_index') },
        { label: 'Fiche client' },
    ]) }}
{% endblock %}

{% block header_actions %}
    {% if customer.user %}
        <a href="{{ path('_admin') }}?_switch_user={{ customer.email }}" class="btn btn-warning">
            <i class="fas fa-user-secret mr-1"></i>
            Se connecter en tant que {{ customer.fullName }}
        </a>
    {% endif %}
{% endblock %}

{% block body %}

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Informations personnelles</h3>
                </div>
                <div class="card-body">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 30%">Prénom</th>
                            <td>{{ customer.firstName }}</td>
                        </tr>
                        <tr>
                            <th>Nom</th>
                            <td>{{ customer.lastName }}</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>{{ customer.email }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h3 class="card-title">Commandes</h3>
                </div>
                <div class="card-body p-0">
                    <table class="table table-striped mb-0">
                        <thead>
                            <tr>
                                <th>Numéro</th>
                                <th>Date</th>
                                <th>Statut</th>
                                <th class="text-right">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for order in customer.orders %}
                                <tr>
                                    <td>{{ order.number }}</td>
                                    <td>{{ order.checkoutCompletedAt ? order.checkoutCompletedAt|date('d/m/Y H:i') : '-' }}</td>
                                    <td>
                                        <span class="badge badge-info">{{ order.state }}</span>
                                    </td>
                                    <td class="text-right">{{ (order.total / 100)|number_format(2, ',', ' ') }} €</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Aucune commande pour ce client.</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

{% endblock %}
